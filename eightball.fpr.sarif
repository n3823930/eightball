tion.line\" /> 行的 <Replace key=\"PrimaryCall.name\" /> 的檔案系統路徑引數，可讓他們存取或修改原本受保護的檔案。\r\n允許使用者輸入來控制檔案系統操作中使用的路徑，可讓攻擊者存取或修改原本受保護的系統資源。"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":12,"snippet":{"text":"\t\tnew FileReader(filename).read(buffer);"}},"contextRegion":{"startLine":9,"endLine":15,"snippet":{"text":"\t\t} catch (Exception e) {\n\t\t\tSystem.out.println(\"Invalid input.\");\n\t\t}\n\t\tnew FileReader(filename).read(buffer);\n\t\tSystem.out.println(buffer);\n\t}\n}\n"}}}}],"codeFlows":[{"threadFlows":[{"locations":[{"index":1},{"index":0},{"index":2},{"index":3},{"location":{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":12,"snippet":{"text":"\t\tnew FileReader(filename).read(buffer);"}},"contextRegion":{"startLine":9,"endLine":15,"snippet":{"text":"\t\t} catch (Exception e) {\n\t\t\tSystem.out.println(\"Invalid input.\");\n\t\t}\n\t\tnew FileReader(filename).read(buffer);\n\t\tSystem.out.println(buffer);\n\t}\n}\n"}}},"message":{"text":"FileReader(0)"}},"kinds":["call","function"]}]}]}],"relatedLocations":[{"id":1,"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":12,"startColumn":18}}}],"properties":{"InstanceSeverity":"5.0","Confidence":"5.0"}},{"ruleId":"823FE039-A7FE-4AAD-B976-9EC53FFE4A59","ruleIndex":0,"message":{"text":"攻擊者可以控制在 <Replace key=\"PrimaryLocation.file\" /> 中第 <Replace key=\"PrimaryLocation.line\" /> 行的 <Replace key=\"PrimaryCall.name\" /> 的檔案系統路徑引數，可讓他們存取或修改原本受保護的檔案。\r\n允許使用者輸入來控制檔案系統操作中使用的路徑，可讓攻擊者存取或修改原本受保護的系統資源。"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":12,"snippet":{"text":"\t\tnew FileReader(filename).read(buffer);"}},"contextRegion":{"startLine":9,"endLine":15,"snippet":{"text":"\t\t} catch (Exception e) {\n\t\t\tSystem.out.println(\"Invalid input.\");\n\t\t}\n\t\tnew FileReader(filename).read(buffer);\n\t\tSystem.out.println(buffer);\n\t}\n}\n"}}}}],"codeFlows":[{"threadFlows":[{"locations":[{"index":1},{"index":0},{"location":{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":12,"snippet":{"text":"\t\tnew FileReader(filename).read(buffer);"}},"contextRegion":{"startLine":9,"endLine":15,"snippet":{"text":"\t\t} catch (Exception e) {\n\t\t\tSystem.out.println(\"Invalid input.\");\n\t\t}\n\t\tnew FileReader(filename).read(buffer);\n\t\tSystem.out.println(buffer);\n\t}\n}\n"}}},"message":{"text":"FileReader(0)"}},"kinds":["call","function"]}]}]}],"relatedLocations":[{"id":1,"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":12,"startColumn":18}}}],"properties":{"InstanceSeverity":"5.0","Confidence":"5.0"}}],"tool":{"driver":{"name":"MicroFocus Fortify SCA","version":"26.1.0.0059","rules":[{"id":"823FE039-A7FE-4AAD-B976-9EC53FFE4A59","name":"Input Validation and Representation/Path Manipulation","fullDescription":{"text":"當發生以下兩種情況的時候，會產生 path manipulation 錯誤：\r\n\r\n1.攻擊者可以指定在檔案系統操作中所使用的路徑。\r\n\r\n2. 攻擊者可藉由指定資源來取得一般情況下不被允許的權限。\r\n\r\n例如，程式可能會讓攻擊者能夠覆寫指定的檔案，或是能夠在攻擊者控制的組態下執行。\r\n\r\n在此案例中，攻擊者可以指定在 <Replace key=\"SourceLocation.file\" /> 中第 <Replace key=\"SourceLocation.line\" /> 行的 <Replace key=\"SourceFunction\" link=\"SourceLocation\" /> 進入程式的值，而且可使用此值存取 <Replace key=\"SinkLocation.file\" /> 中第 <Replace key=\"SinkLocation.line\" /> 行的 <Replace key=\"SinkFunction\" link=\"SinkLocation\" /> 的檔案系統資源。\r\n\r\n儘管在此案例中的資料為數字，卻未經驗證而依然算是惡意資料，因此系統依然會報告此弱點，但其優先順序值則會減低。　\r\n\r\n**範例 1：**以下的程式碼使用 HTTP 要求的輸入建立一個檔案名稱。程式設計師沒有考慮到攻擊者能夠提供檔案名稱類似「`../../tomcat/conf/server.xml`」的可能性，這會導致應用程式刪除本身其中一個組態設定檔案。\r\n\r\n`\nString rName = request.getParameter(\"reportName\");\nFile rFile = new File(\"/usr/local/apfr/reports/\" + rName);\n...\nrFile.delete();\n`\r\n\r\n**範例 2：**以下程式碼使用來自配置檔案的輸入，來決定要開啟哪個檔案並返回給使用者。如果程式需要適當權限才能執行，且惡意使用者可以變更配置檔案，則他們可以使用程式來讀取系統中結尾副檔名為 `.txt` 的任意檔案。\r\n\r\n`\nfis = new FileInputStream(cfg.getProperty(\"sub\")+\".txt\");\namt = fis.read(arr);\nout.println(arr);\n`\r\n\r\n有人認為在行動環境中，典型的弱點 (例如 Path Manipulation) 不會產生影響，因為使用者為何會攻擊自己呢？但是請謹記，行動平台的本質是從多種來源下載，並在相同裝置上一起執行的應用程式。在金融應用程式旁執行惡意程式碼的可能性很高，這必然會擴大行動應用程式的受攻擊面，將程序之間的通訊包括在內。\r\n\r\n**範例 3：**以下程式碼改寫 `Example 1` 以適用於 Android 平台。\r\n\r\n`\n...\n        String rName = this.getIntent().getExtras().getString(\"reportName\");\n        File rFile = getBaseContext().getFileStreamPath(rName);\n...\n        rFile.delete();\n...\n`"},"shortDescription":{"text":"攻擊者可以控制在 <Replace key=\"PrimaryLocation.file\" /> 中第 <Replace key=\"PrimaryLocation.line\" /> 行的 <Replace key=\"PrimaryCall.name\" /> 的檔案系統路徑引數，可讓他們存取或修改原本受保護的檔案。\r\n允許使用者輸入來控制檔案系統操作中使用的路徑，可讓攻擊者存取或修改原本受保護的系統資源。"},"guid":"823fe039-a7fe-4aad-b976-9ec53ffe4a59","defaultConfiguration":{"properties":{"DefaultSeverity":"5.0"}},"properties":{"Impact":"3.0","Accuracy":"4.0","Probability":"4.0"},"relationships":[{"target":{"id":"22","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]},{"target":{"id":"73","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]}]},{"id":"F5479615-A5E9-4BC9-BDBF-6FAC2B062F80","name":"API Abuse/Unchecked Return Value","fullDescription":{"text":"Java 程式設計師經常會誤解 `read()` 以及許多 `java.io` 類別其中一部分的相關方法。Java 中絕大多數的錯誤以及不尋常的事件都會導致異常拋出。(這是 Java 勝過 C 語言之類程式語言的優點之一：異常可讓程式設計師更容易思考是哪裡出錯了。)但是，如果只有一小部分的資料可使用，串流與讀取器類別不會認為這是不尋常或異常現象。這些類別只會將這些小量的資料加入回傳緩衝區，並且把回傳值設為讀取的位元組或字元數。因此，並不能保證回傳的資料量等於要求的資料量。\r\n\r\n這樣一來，程式設計師必須檢查從 `read()` 回傳的值以及其他 IO 方法，並確保他們能夠接收到預期的資料數量。\r\n\r\n在此案例中，<Replace key=\"PrimaryCall.name\" link=\"PrimaryLocation\" /> 的值並不會在 <Replace key=\"PrimaryLocation.file\" /> 中的第 <Replace key=\"PrimaryLocation.line\" /> 行進行檢查。\r\n\r\n**範例 1：**以下程式碼會在一組使用者中循環，讀取每個使用者的私人資料檔案。程式設計師會假設這些檔案大小一直剛好是 1KB，因而忽略了來自 `read()` 的回傳值。如果攻擊者可以建立更小的檔案，那麼程式會回收前一個使用者剩餘的資料，並將這些資料當作攻擊者的所有物來處理。\r\n\r\n`\nFileInputStream fis;\nbyte[] byteArray = new byte[1024];\nfor (Iterator i=users.iterator(); i.hasNext();) {\n    String userName = (String) i.next();\n    String pFileName = PFILE_ROOT + \"/\" + userName;\n    FileInputStream fis = new FileInputStream(pFileName);\n    fis.read(byteArray); // the file is always 1k bytes\n    fis.close();\n    processPFile(userName, byteArray);\n}\n`"},"shortDescription":{"text":"<Replace key=\"PrimaryLocation.file\" /> 中的 <Replace key=\"EnclosingFunction.name\" /> 方法會忽略由第 <Replace key=\"PrimaryLocation.line\" /> 行的 <Replace key=\"PrimaryCall.name\" /> 回傳的值，這可能讓程式忽略無法預期的狀態與情況。\r\n忽略某個方法的回傳值會導致程式忽略無法預期的狀態與情況。"},"guid":"f5479615-a5e9-4bc9-bdbf-6fac2b062f80","defaultConfiguration":{"properties":{"DefaultSeverity":"2.0"}},"properties":{"Impact":"2.0","Accuracy":"4.0","Probability":"1.0"},"relationships":[{"target":{"id":"252","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]},{"target":{"id":"754","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]}]},{"id":"74714BFC-EDF7-445B-8672-0996214D5845","name":"Code Quality/Unreleased Resource/Streams","fullDescription":{"text":"程式可能會無法釋出系統資源。\r\n\r\n在此案例中，程式不會釋放 <Replace key=\"FirstTraceLocation.file\" /> 中第 <Replace key=\"FirstTraceLocation.line\" /> 行配置的資源，但執行此操作的程式路徑會存在。\r\n\r\n資源洩漏至少有兩種常見原因：\r\n\r\n- 錯誤條件以及其他異常情況。\r\n\r\n- 不確定程式的哪一部份負責釋放資源。\r\n\r\n大部分的 Unreleased Resource 問題都會導致一般軟體可靠性問題，但是如果攻擊者蓄意觸發資源洩漏的話，攻擊者就可能會藉由耗盡資源集區的方式來發動 Denial of Service 攻擊。\r\n\r\n**範例 1：**下列方法絕對不會關閉它所開啟的檔案控制碼。用於 `FileInputStream` 的 `finalize()` 方法最終會呼叫 `close()`，但是並不保證在叫用 `finalize()` 方法前會經過多少時間。因此，在繁忙的環境中，這可能會導致 JVM 用盡它所有的檔案控制碼。\n`\nprivate void processFile(String fName) throws FileNotFoundException, IOException {\n  FileInputStream fis = new FileInputStream(fName);\n  int sz;\n  byte[] byteArray = new byte[BLOCK_SIZE];\n  while ((sz = fis.read(byteArray)) != -1) {\n    processBytes(byteArray, sz);\n  }\n}\n`"},"shortDescription":{"text":"<Replace key=\"PrimaryLocation.file\" /> 中的 <Replace key=\"EnclosingFunction.name\" /> 函數有時會無法釋出由第 <Replace key=\"FirstTraceLocation.line\" /> 行的 <Replace key=\"FirstTransitionFunction\" /> 所配置的系統資源。\r\n程式可能會無法釋出系統資源。"},"guid":"74714bfc-edf7-445b-8672-0996214d5845","defaultConfiguration":{"properties":{"DefaultSeverity":"4.0"}},"properties":{"Impact":"2.5","Accuracy":"3.0","Probability":"1.0"},"relationships":[{"target":{"id":"772","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]}]},{"id":"0B15E7B7-B74B-47F9-B383-DA739797D00C","name":"Input Validation and Representation/Path Manipulation","fullDescription":{"text":"當發生以下兩種情況的時候，會產生 path manipulation 錯誤：\r\n\r\n1.攻擊者可以指定在檔案系統操作中所使用的路徑。\r\n\r\n2. 攻擊者可藉由指定資源來取得一般情況下不被允許的權限。\r\n\r\n例如，程式可能會讓攻擊者能夠覆寫指定的檔案，或是能夠在攻擊者控制的組態下執行。\r\n\r\n在此案例中，攻擊者可以指定在 <Replace key=\"SourceLocation.file\" /> 中第 <Replace key=\"SourceLocation.line\" /> 行的 <Replace key=\"SourceFunction\" link=\"SourceLocation\" /> 進入程式的值，而且可使用此值存取 <Replace key=\"SinkLocation.file\" /> 中第 <Replace key=\"SinkLocation.line\" /> 行的 <Replace key=\"SinkFunction\" link=\"SinkLocation\" /> 的檔案系統資源。\r\n\r\n儘管在此案例中的資料為數字，卻未經驗證而依然算是惡意資料，因此系統依然會報告此弱點，但其優先順序值則會減低。　\r\n\r\n**範例 1：**以下的程式碼使用 HTTP 要求的輸入建立一個檔案名稱。程式設計師沒有考慮到攻擊者能夠提供檔案名稱類似「`../../tomcat/conf/server.xml`」的可能性，這會導致應用程式刪除本身其中一個組態設定檔案。\r\n\r\n`\nString rName = request.getParameter(\"reportName\");\nFile rFile = new File(\"/usr/local/apfr/reports/\" + rName);\n...\nrFile.delete();\n`\r\n\r\n**範例 2：**以下程式碼使用來自配置檔案的輸入，來決定要開啟哪個檔案並返回給使用者。如果程式需要適當權限才能執行，且惡意使用者可以變更配置檔案，則他們可以使用程式來讀取系統中結尾副檔名為 `.txt` 的任意檔案。\r\n\r\n`\nfis = new FileInputStream(cfg.getProperty(\"sub\")+\".txt\");\namt = fis.read(arr);\nout.println(arr);\n`\r\n\r\n有人認為在行動環境中，典型的弱點 (例如 Path Manipulation) 不會產生影響，因為使用者為何會攻擊自己呢？但是請謹記，行動平台的本質是從多種來源下載，並在相同裝置上一起執行的應用程式。在金融應用程式旁執行惡意程式碼的可能性很高，這必然會擴大行動應用程式的受攻擊面，將程序之間的通訊包括在內。\r\n\r\n**範例 3：**以下程式碼改寫 `Example 1` 以適用於 Android 平台。\r\n\r\n`\n...\n        String rName = this.getIntent().getExtras().getString(\"reportName\");\n        File rFile = getBaseContext().getFileStreamPath(rName);\n...\n        rFile.delete();\n...\n`"},"shortDescription":{"text":"攻擊者可以控制在 <Replace key=\"PrimaryLocation.file\" /> 中第 <Replace key=\"PrimaryLocation.line\" /> 行的 <Replace key=\"PrimaryCall.name\" /> 的檔案系統路徑引數，可讓他們存取或修改原本受保護的檔案。\r\n允許使用者輸入來控制檔案系統操作中使用的路徑，可讓攻擊者存取或修改原本受保護的系統資源。"},"guid":"0b15e7b7-b74b-47f9-b383-da739797d00c","defaultConfiguration":{"properties":{"DefaultSeverity":"5.0"}},"properties":{"Impact":"2","Probability":"1","Accuracy":"4.0"},"relationships":[{"target":{"id":"22","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]},{"target":{"id":"73","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]}]},{"id":"625EEE1F-464F-42DC-85D6-269A637EF747","name":"Encapsulation/J2EE Bad Practices/Leftover Debug Code","fullDescription":{"text":"開發作業一般會為了除錯或測試目而增加一些「後門」程式碼，這些程式碼不會隨應用程式一起提供或部署。當這類除錯程式碼意外地留在應用程式中時，會導致應用程式開放在未預期的互動模式。這些後門入口點很容易造成安全問題，因為在設計或者測試期間，並沒有將它們考慮在內，並且不會出現在應用程式設計中的操作環境中。\r\n\r\n遭遺忘的除錯程式碼中最常見的示例，是出現在 Web 應用程式中的 `main()` 方法。雖然這在軟體產品的開發過程中是完全可接受的，但是屬於 J2EE 應用程式那部分的類別不應該定義 `main()`。"},"shortDescription":{"text":"<Replace key=\"EnclosingClass.name\" /> 類別包含除錯程式碼，這可能會在部署的 Web 應用程式中建立不預期的進入點。\r\n除錯程式碼可能會在部署的 Web 應用程式中建立不預期的進入點。"},"guid":"625eee1f-464f-42dc-85d6-269a637ef747","defaultConfiguration":{"properties":{"DefaultSeverity":"2.0"}},"properties":{"Impact":"2.0","Accuracy":"4.0","Probability":"1.0"},"relationships":[{"target":{"id":"489","toolComponent":{"name":"CWE","guid":"25f72d7e-8a92-459d-ad67-64853f788765"}},"kinds":["relevant"]}]},{"id":"3F0B36DD-4C18-4E09-89BC-D464754B8B760","guid":"3f0b36dd-4c18-4e09-89bc-d464754b8b76"}],"supportedTaxonomies":[{"name":"CWE","index":0,"guid":"25f72d7e-8a92-459d-ad67-64853f788765"}]}},"invocations":[{"commandLine":"[REMOVED]insourceanalyzer.exe -scan -pid-file C:\\Users\\n3823\\AppData\\Local\\Temp\\PID14887952598853013676.tmp -b eightball -machine-output -format fpr -f D:\\OpenText_SAST_Fortify_Samples_26.1.0\\eightball.fpr -sc classic","startTimeUtc":"2026-03-24T10:18:00.000Z","executionSuccessful":true,"machine":"MSI-NORMAN","account":"n3823","properties":{"Platform":"Windows 11"}}],"automationDetails":{"id":"/","guid":"2d4fb3fc-ed3e-483e-9f1a-ffba76a7c667"},"columnKind":"utf16CodeUnits","threadFlowLocations":[{"location":{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":6,"snippet":{"text":"\t\tString filename = args[0];"}},"contextRegion":{"startLine":3,"endLine":9,"snippet":{"text":"public class EightBall {\n\tpublic static void main(String args[]) throws Exception {\n\t\tchar[] buffer = new char[1024];\n\t\tString filename = args[0];\n\t\ttry {\n\t\t\tfilename = \"\" + (Integer.parseInt(filename) % 3);\n\t\t} catch (Exception e) {\n"}}},"message":{"text":"Assignment to filename"}},"kinds":["acquire","resource"]},{"location":{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":4,"snippet":{"text":"\tpublic static void main(String args[]) throws Exception {"}},"contextRegion":{"startLine":1,"endLine":7,"snippet":{"text":"import java.io.FileReader;\n\npublic class EightBall {\n\tpublic static void main(String args[]) throws Exception {\n\t\tchar[] buffer = new char[1024];\n\t\tString filename = args[0];\n\t\ttry {\n"}}},"message":{"text":"main(0)"}},"kinds":["call","function"]},{"location":{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":8,"snippet":{"text":"\t\t\tfilename = \"\" + (Integer.parseInt(filename) % 3);"}},"contextRegion":{"startLine":5,"endLine":11,"snippet":{"text":"\t\tchar[] buffer = new char[1024];\n\t\tString filename = args[0];\n\t\ttry {\n\t\t\tfilename = \"\" + (Integer.parseInt(filename) % 3);\n\t\t} catch (Exception e) {\n\t\t\tSystem.out.println(\"Invalid input.\");\n\t\t}\n"}}},"message":{"text":"parseInt(0 : return)"}},"kinds":["call","function","return"]},{"location":{"physicalLocation":{"artifactLocation":{"uri":"EightBall.java"},"region":{"startLine":8,"snippet":{"text":"\t\t\tfilename = \"\" + (Integer.parseInt(filename) % 3);"}},"contextRegion":{"startLine":5,"endLine":11,"snippet":{"text":"\t\tchar[] buffer = new char[1024];\n\t\tString filename = args[0];\n\t\ttry {\n\t\t\tfilename = \"\" + (Integer.parseInt(filename) % 3);\n\t\t} catch (Exception e) {\n\t\t\tSystem.out.println(\"Invalid input.\");\n\t\t}\n"}}},"message":{"text":"Assignment to filename"}},"kinds":["acquire","resource"]}],"taxonomies":[{"guid":"25f72d7e-8a92-459d-ad67-64853f788765","name":"CWE","organization":"MITRE","shortDescription":{"text":"The MITRE Common Weakness Enumeration"},"taxa":[{"id":"22"},{"id":"73"},{"id":"489"},{"id":"772"},{"id":"252"},{"id":"754"}]}]}]}